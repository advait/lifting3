{
  "name": "lifting3",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp build",
    "cf-typegen": "wrangler types",
    "check": "pnpm cf-typegen && react-router typegen && vp check",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply lifting3 --local",
    "db:migrate:remote": "wrangler d1 migrations apply lifting3 --remote",
    "db:seed:local": "node --experimental-strip-types ./scripts/seed-d1-workouts.ts --local",
    "db:seed:remote": "node --experimental-strip-types ./scripts/seed-d1-workouts.ts --remote",
    "deploy": "pnpm build && wrangler deploy",
    "dev": "vp dev",
    "fix": "pnpm cf-typegen && react-router typegen && vp check --fix",
    "postinstall": "pnpm cf-typegen",
    "preview": "pnpm build && vp preview",
    "typecheck": "pnpm cf-typegen && react-router typegen && tsc -b",
    "validate:workout-interchange": "node --experimental-strip-types ./scripts/validate-workout-interchange.ts",
    "verify:lifting2-exercises": "node --experimental-strip-types ./scripts/verify-lifting2-exercise-compat.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.36",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.14.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.5",
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.18",
    "vite-plus": "0.1.18",
    "wrangler": "^4.83.0"
  },
  "packageManager": "pnpm@10.33.0"
}
