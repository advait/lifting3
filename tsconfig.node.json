{
  "extends": "./tsconfig.json",
  "include": [
    "scripts/**/*.ts",
    "app/features/**/*.ts",
    "app/lib/.server/**/*.ts",
    "types/**/*.d.ts"
  ],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "composite": true,
    "strict": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler"
  }
}
